{
  "name": "template-vite-ts",
  "description": "A Phaser 3 TypeScript template using Vite.",
  "version": "1.4.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phaserjs/template-vite-ts.git"
  },
  "author": "Phaser Studio <support@phaser.io> (https://phaser.io/)",
  "license": "MIT",
  "licenseUrl": "http://www.opensource.org/licenses/mit-license.php",
  "dependencies": {
    "phaser": "^4.2.0",
    "terser": "^5.39.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "prettier": "^3.8.4",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.61.1",
    "vite": "^6.3.1",
    "vitest": "^4.1.9"
  },
  "bugs": {
    "url": "https://github.com/phaserjs/template-vite-ts/issues"
  },
  "homepage": "https://github.com/phaserjs/template-vite-ts#readme",
  "scripts": {
    "dev": "node log.js dev & vite --config vite/config.dev.mjs",
    "build": "node log.js build & vite --config vite/config.prod.mjs",
    "dev-nolog": "vite --config vite/config.dev.mjs",
    "build-nolog": "vite --config vite/config.prod.mjs",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,js,mjs}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,mjs}\"",
    "typecheck": "tsc --noEmit"
  }
}
